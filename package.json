{
  "name": "rotm",
  "version": "2.0.1",
  "main": "server.js",
  "description": "A Home Office application for reporting online terrorist material.",
  "license": "GPL-2.0",
  "engines": {
    "node": ">=20.19.0 <21.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/UKHomeOffice/rotm.git"
  },
  "bugs": "https://github.com/UKHomeOffice/rotm/issues",
  "scripts": {
    "start": "node server.js",
    "start:dev": "[ -f .env ] && hof-build watch --env || hof-build watch",
    "test": "yarn run test:lint",
    "test:lint": "eslint . --config ./node_modules/eslint-config-hof/default.js",
    "test:unit": "mocha \"test/test.setup.js\" \"test/_unit/**/*.spec.js\"",
    "build": "hof-build",
    "postinstall": "yarn run build"
  },
  "author": "HomeOffice",
  "dependencies": {
    "@google-cloud/recaptcha-enterprise": "^6.4.1",
    "busboy-body-parser": "^0.3.2",
    "device": "^0.3.12",
    "express": "^5.2.1",
    "hof": "~23.0.4",
    "jimp": "^1.6.1",
    "jpeg-js": "^0.4.4",
    "lodash": "^4.18.1",
    "moment": "^2.30.1",
    "proxyquire": "^2.1.3",
    "uuid": "^11.1.1",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "chai": "^6.2.2",
    "chai-as-promised": "^8.0.2",
    "eslint": "^8.57.1",
    "eslint-config-hof": "^1.3.4",
    "mocha": "^11.7.5",
    "sinon": "^21.1.2",
    "sinon-chai": "^4.0.1"
  },
  "resolutions": {
    "nodemailer": ">=8.0.7"
  }
}
